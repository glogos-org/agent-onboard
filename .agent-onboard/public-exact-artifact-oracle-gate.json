{
  "schema": "agent-onboard-public-exact-artifact-oracle-gate-001",
  "package_name": "agent-onboard",
  "release_line": "public_exact_artifact_oracle_gate",
  "work_item_id": "P1S3M5W39",
  "status": "closed",
  "purpose": "Admit a public-safe local exact artifact oracle for npm pack file-list, tarball digest, and fresh installed CLI smoke evidence.",
  "commands": {
    "oracle": "agent-onboard release --artifact-oracle",
    "oracle_check": "agent-onboard release --artifact-oracle-check",
    "fast_plan": "agent-onboard check --plan [--json|--text]"
  },
  "oracle": {
    "pack_command": "npm pack --json --pack-destination <temp>",
    "fresh_install_command": "npm install --no-audit --no-fund --ignore-scripts <local-tgz>",
    "smoke_commands": [
      "node node_modules/agent-onboard/cli/agent-onboard.js --version",
      "node node_modules/agent-onboard/cli/agent-onboard.js release --check"
    ],
    "records_exact_tgz_sha256": true,
    "records_npm_integrity": true,
    "records_exact_file_list": true,
    "raw_stdout_inlined": false,
    "raw_stderr_inlined": false
  },
  "fast_runner_policy": {
    "check_fast_runs_oracle": false,
    "omitted_slow_check_id": "release-artifact-oracle",
    "omitted_reason_key": "package_manager_projection"
  },
  "boundary": {
    "writes_package_root": false,
    "writes_target_repository_state": false,
    "writes_temp_files": true,
    "removes_temp_files": true,
    "runs_package_manager": true,
    "child_process_spawn": true,
    "publishes_package": false,
    "mutates_registry": false,
    "network_required": false
  }
}
