{
  "schema": "agent-onboard-public-package-source-manifest-service-gate-001",
  "package_name": "agent-onboard",
  "version": "0.0.110",
  "release_line": "public_package_source_manifest_service_gate",
  "title": "Public package source manifest service gate",
  "summary": "Admits a read-only package-domain source manifest service that content-addresses every projected npm package file with file_id ni:///sha-256;... identifiers, validates the manifest through release --surface-check, keeps raw sha256 out of public output, and keeps source-only hash-cache state outside package.json#files.",
  "runtime_surface": {
    "service": "cli/agent_onboard/domains/package/services/source-manifest-service.js",
    "exports": [
      "describeSourceManifestServiceSeed",
      "createPackageSourceManifestService",
      "digestBytes",
      "projectedPackageFiles"
    ],
    "release_check_integration": "agent-onboard release --surface-check"
  },
  "boundary": {
    "writes_files": false,
    "runs_package_manager": false,
    "publishes_package": false,
    "mutates_registry": false,
    "raw_sha256_exposed": false,
    "hash_cache_projected_into_package": false
  },
  "checks": [
    "node -c cli/agent_onboard/domains/package/services/source-manifest-service.js",
    "node -c cli/agent_onboard/runtime-composer.js",
    "node -c test/agent-onboard.test.js",
    "npm test",
    "node cli/agent-onboard.js release --surface-check",
    "node cli/agent-onboard.js release --check",
    "node cli/agent-onboard.js release --version-sprawl-check"
  ]
}
