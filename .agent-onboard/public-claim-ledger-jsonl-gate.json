{
  "schema": "agent-onboard-public-claim-ledger-jsonl-gate-001",
  "package_name": "agent-onboard",
  "release_line": "public_claim_ledger_jsonl_gate",
  "work_item_id": "P1S3M5W37",
  "status": "closed",
  "purpose": "Admit a compact JSONL claim-event ledger command surface for public coordination without inlining raw claim entries by default.",
  "commands": {
    "validate_ledger": "agent-onboard claim --validate-ledger [--file <path>] [--json|--text]",
    "append_event": "agent-onboard claim --append --dry-run|--write --work-item-id <id> --actor <actor> [--event-type claim_proposed|claim_merged] [--claim-id <id>] [--note <note>]"
  },
  "canonical_files": {
    "claims_ledger": ".agent-onboard/claims.jsonl",
    "claims_index": ".agent-onboard/claims.index.json"
  },
  "output_policy": {
    "raw_claims_ledger_inlined_by_validation": false,
    "raw_claim_event_notes_inlined_by_validation": false,
    "validation_output_shape": "compact counts and boundary metadata"
  },
  "boundary": {
    "validate_ledger_writes_files": false,
    "append_requires_explicit_write_or_dry_run": true,
    "append_writes_exactly_one_jsonl_event": true,
    "append_mutates_work_items_ledger": false,
    "git_mutation": false,
    "installs_dependencies": false,
    "runs_package_manager": false,
    "runs_build_test_deploy": false,
    "publishes_package": false,
    "mutates_registry": false,
    "network": false
  }
}
