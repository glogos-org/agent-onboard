{
  "schema": "agent-onboard-public-target-memory-descriptor-product-gate-001",
  "work_item_id": "P1S3M5W10",
  "title": "Public target memory descriptor product gate",
  "status": "closed",
  "package_name": "agent-onboard",
  "version": "0.0.117",
  "release_line": "public_target_memory_descriptor_product_gate",
  "commands": [
    "agent-onboard target memory --preview",
    "agent-onboard target memory --json",
    "agent-onboard target memory --text"
  ],
  "purpose": "Expose a read-only metadata-only descriptor of known target repository memory, instruction, identity, and target-owned state surfaces before agents import raw context.",
  "known_surface_candidates": [
    "AGENTS.md",
    "llms.txt",
    "README.md",
    "CLAUDE.md",
    ".github/copilot-instructions.md",
    ".cursor/rules",
    ".claude/agents",
    ".claude/commands",
    ".claude/skills",
    ".repo-identifier",
    ".agent-onboard/target.json",
    ".agent-onboard/project.json",
    ".agent-onboard/work-items.json",
    ".agent-onboard/authority-path.json",
    ".agent-onboard/claims.jsonl",
    ".agent-onboard/target-memory.json"
  ],
  "output_policy": {
    "metadata_only": true,
    "file_contents_inlined": false,
    "target_ai_memory_content_imported": false,
    "provider_authority_files_inlined": false,
    "stores_target_ai_file_metadata_only": true
  },
  "boundary": {
    "writes_files": false,
    "writes_target_repository_state": false,
    "reads_file_contents": false,
    "stores_target_ai_file_contents": false,
    "imports_hidden_model_memory": false,
    "treats_chat_history_as_authority": false,
    "scans_arbitrary_private_files": false,
    "bounded_known_path_probe_only": true,
    "installs_dependencies": false,
    "runs_build_test_deploy": false,
    "runs_managed_project_commands": false,
    "git_mutation": false,
    "publishes_package": false,
    "network": false
  },
  "notes": [
    "This gate does not admit target memory --write or .agent-onboard/target-memory.json materialization.",
    "This gate keeps the compact npm package file allowlist unchanged.",
    "The descriptor reports path presence, observed kind, bytes for files, authority grouping, and read policy only."
  ]
}
